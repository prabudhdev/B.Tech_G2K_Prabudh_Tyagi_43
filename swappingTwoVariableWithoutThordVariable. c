#include <stdio.h>

int main() {

    int a = 10, b = 20;

    printf("Before swap: a = %d, b = %d\n", a, b);

    // Logic: use the difference and sum to swap
    a = a + b; // a becomes 30
    b = a - b; // b becomes 10 (30 - 20)
    a = a - b; // a becomes 20 (30 - 10)

    printf("After swap: a = %d, b = %d\n", a, b);
    return 0;
}
