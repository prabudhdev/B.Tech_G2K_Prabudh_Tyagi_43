#include <stdio.h>
#include <string.h>

struct Student {
    int roll_no;
    char name[50];
    float marks;
};

void displayStudent(struct Student s) {
    printf("\n--- Student Record ---");
    printf("\nRoll Number: %d", s.roll_no);
    printf("\nName:        %s", s.name);
    printf("\nMarks:       %.2f\n", s.marks);
}

int main() {
    int n;
    printf("Enter the number of students: ");
    scanf("%d", &n);

    struct Student s[n];

    // Input Logic
    for(int i = 0; i < n; i++) {
        printf("\nEnter details for student %d:\n", i + 1);
        printf("Roll Number: ");
        scanf("%d", &s[i].roll_no);
        printf("Name: ");
        scanf("%s", s[i].name);
        printf("Marks: ");
        scanf("%f", &s[i].marks);
    }

    // Output Logic
    printf("\nDisplaying all records:");
    for(int i = 0; i < n; i++) {
        displayStudent(s[i]);
    }

    // Simple Search Feature
    int searchRoll;
    printf("\nEnter Roll Number to search: ");
    scanf("%d", &searchRoll);

    int found = 0;
    for(int i = 0; i < n; i++) {
        if(s[i].roll_no == searchRoll) {
            printf("\nStudent Found!");
            displayStudent(s[i]);
            found = 1;
            break;
        }
    }

    if(!found) {
        printf("\nRecord not found.");
    }

    return 0;
}
